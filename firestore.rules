rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - tier: string (free, plus, premium)
    //   - role: string (user, admin)
    //
    // Collection: properties
    // Fields:
    //   - title: string (required)
    //   - location: string (required)
    //   - price: string (required)
    //   - rooms: number
    //   - bathrooms: number
    //   - size: string
    //   - features: list
    //   - imageUrl: string (url)
    //   - type: string (enum: apartment, villa, studio, office)
    //   - ownerUid: string (required)
    //   - companyName: string
    //   - createdAt: timestamp
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "aamr222382@gmail.com" && request.auth.token.email_verified == true ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function canUpload() {
      return isAdmin() || 
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tier in ['plus', 'premium']);
    }

    function isValidProperty(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.location is string && data.location.size() > 0 && data.location.size() < 200 &&
             data.price is string && data.price.size() > 0 && data.price.size() < 50 &&
             data.type in ['apartment', 'villa', 'studio', 'office'] &&
             data.ownerUid is string &&
             (!('rooms' in data) || data.rooms is number) &&
             (!('bathrooms' in data) || data.bathrooms is number) &&
             (!('size' in data) || data.size is string) &&
             (!('features' in data) || data.features is list) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.matches("^https?://.*")));
    }

    function isValidPayment(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.amount > 0 &&
             data.tier in ['plus', 'premium'] &&
             data.walletNumber is string && data.walletNumber.matches("^010[0-9]{8}$") &&
             data.status == 'pending';
    }

    function isValidChatMessage(data) {
      return data.uid is string && 
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() < 10000;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAdmin();
    }

    // Properties Collection
    match /properties/{propertyId} {
      allow read: if true;
      allow create: if (canUpload() || isAdmin()) && 
                      isValidProperty(request.resource.data) && 
                      (request.resource.data.ownerUid == request.auth.uid || isAdmin());
      allow update: if (isAdmin() || (isOwner(resource.data.ownerUid) && canUpload())) && 
                      isValidProperty(request.resource.data);
      allow delete: if isAdmin() || isOwner(resource.data.ownerUid);
    }

    // Payments Collection
    match /payments/{paymentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Chats Collection
    match /chats/{chatId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidChatMessage(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
