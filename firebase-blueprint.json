{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Keywey platform",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User full name" },
        "tier": { "type": "string", "enum": ["free", "plus", "premium"], "description": "Subscription level" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "System role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user joined" }
      },
      "required": ["uid", "email", "tier", "role"]
    },
    "Property": {
      "title": "Property",
      "description": "A real estate listing in Egypt",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the property" },
        "location": { "type": "string", "description": "City and area in Egypt" },
        "price": { "type": "string", "description": "Price in EGP or formatted string" },
        "rooms": { "type": "number", "description": "Number of bedrooms" },
        "bathrooms": { "type": "number", "description": "Number of bathrooms" },
        "size": { "type": "string", "description": "Size in sqm" },
        "features": { "type": "array", "items": { "type": "string" }, "description": "List of amenities" },
        "imageUrl": { "type": "string", "format": "uri", "description": "URL to property image" },
        "type": { "type": "string", "enum": ["apartment", "villa", "studio", "office"], "description": "Property category" },
        "ownerUid": { "type": "string", "description": "UID of the user who owns this listing" },
        "companyName": { "type": "string", "description": "Name of the company/developer" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the listing was added" }
      },
      "required": ["title", "location", "price", "type", "ownerUid"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A subscription payment request",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "UID of the user making the payment" },
        "amount": { "type": "number", "description": "Amount in EGP" },
        "tier": { "type": "string", "enum": ["plus", "premium"], "description": "Target tier" },
        "walletNumber": { "type": "string", "description": "User's Vodafone Cash number" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"], "description": "Payment status" },
        "receiptUrl": { "type": "string", "description": "Optional URL to receipt screenshot" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the request was made" }
      },
      "required": ["uid", "amount", "tier", "walletNumber", "status"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User profiles and subscription data"
    },
    "properties": {
      "schema": "Property",
      "description": "Collection of available property listings"
    },
    "payments": {
      "schema": "Payment",
      "description": "Subscription payment requests"
    }
  }
}
